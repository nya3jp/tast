      },
      "writtenOn": "2019-06-11T16:46:22Z",
      "side": 1,
      "message": "E.g.:\n\nt :\u003d make(chan bool, 1)\n\ntimedout :\u003d func() bool {\n  select {\n  case _, ok \u003c- t: return True\n  default: return False\n  }\n}\n\nretc ;\u003d make(chan error, 1)\n\nvar sess *ssh.Session\ngo func() {\n  s, err :\u003d ...NewSession()\n  if err !\u003d nil {\n    retc \u003c- err\n    return\n  }\n  if timedout() {\n    s.Close()\n    return\n  }\n  ... setup pipes ...\n  sess \u003d s\n  retc \u003c- nil\n  // Make sure that main thread returns success.\n  if ok :\u003d \u003c-t; !ok {\n    s.Close()\n    return\n  }\n}()\n\nselect {\ncase err :\u003d \u003c-retc:\n  if err !\u003d nil {\n    return err\n  }\ncase \u003c-ctx.Done():\n  t \u003c- True\n  return ctx.Err()\n}\nc.sess \u003d sess\nt \u003c- False\nreturn nil\n\nWDYT?",
