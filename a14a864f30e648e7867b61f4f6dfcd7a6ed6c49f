      "side": 1,
      "message": "nit: we can use cmd.Output() instead and don\u0027t provide Stderr",
      "range": {
        "startLine": 372,
        "startChar": 1,
        "endLine": 372,
        "endChar": 24
      },
      "revId": "a14a864f30e648e7867b61f4f6dfcd7a6ed6c49f",
