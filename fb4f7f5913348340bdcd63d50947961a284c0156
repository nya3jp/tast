      "writtenOn": "2017-08-24T00:02:20Z",
      "side": 1,
      "message": "i\u0027m trying to decide how i feel about https://github.com/golang/go/wiki/CodeReviewComments#interfaces. opinions?",
      "revId": "fb4f7f5913348340bdcd63d50947961a284c0156",
