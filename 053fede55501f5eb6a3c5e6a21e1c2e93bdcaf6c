      "writtenOn": "2020-10-09T09:58:42Z",
      "side": 1,
      "message": "Hi Xibin,\n\nThanks, it\u0027s nice to support runtime variables in services.\n\nStarting from higher-level comments...",
      "revId": "053fede55501f5eb6a3c5e6a21e1c2e93bdcaf6c",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba"
