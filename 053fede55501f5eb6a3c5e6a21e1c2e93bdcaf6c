      "writtenOn": "2020-10-09T09:58:42Z",
      "side": 1,
      "message": "Tests should declare runtime variables upfront in their metadata (testing.Test.Vars). Services should do the same thing.\n\nCan you add Vars in testing.Service, and add a check it here, just like testing.State.Var does?",
      "range": {
        "startLine": 65,
        "startChar": 23,
        "endLine": 65,
        "endChar": 26
      },
      "revId": "053fede55501f5eb6a3c5e6a21e1c2e93bdcaf6c",
