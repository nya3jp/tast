    {
      "key": {
        "uuid": "1561af8d_0225a135",
        "filename": "src/chromiumos/tast/ssh/exec.go",
        "patchSetId": 2
      },
      "lineNbr": 335,
      "author": {
        "id": 1150179
      },
      "writtenOn": "2020-04-27T10:15:48Z",
      "side": 1,
      "message": "I tought about it, but I was not sure what the logger\u0027s type should be. Should it be func(string) or func(...interface{}) to match with the type of s.Log?\n \nGiven most of the use cases of testexec.DumpLog come after error check (i.e. replacable with DumpLogOnError option), I\u0027d like to keep the method private and see what people say.",
      "parentUuid": "020d7947_6aaf57ef",
      "range": {
        "startLine": 335,
        "startChar": 14,
        "endLine": 335,
        "endChar": 21
      },
      "revId": "ed5209a2209ac7341a4e01575c81cd52c0fddad7",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
