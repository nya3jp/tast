      "author": {
        "id": 1115919
      },
      "writtenOn": "2019-09-04T03:47:04Z",
      "side": 1,
      "message": "Ok, Nanoseconds sounds reasonable, practically, I think, then.",
      "parentUuid": "9185755d_7999541c",
      "range": {
