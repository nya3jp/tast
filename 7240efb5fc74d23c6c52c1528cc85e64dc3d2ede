      "writtenOn": "2019-03-28T09:28:10Z",
      "side": 1,
      "message": "This is a race condition; pw.epollFD can be already closed by the other goroutine.\n\nsyscall.Close(pw.epollFD) should be called by the epoll goroutine. I\u0027m not sure what is the typical way to fix this, but I guess one way is to create a new pipe pair and register the read end to epoll set, whereas the write end is closed to indicate the cleanup by the other goroutine.",
      "range": {
        "startLine": 42,
        "startChar": 15,
        "endLine": 42,
        "endChar": 43
      },
      "revId": "7240efb5fc74d23c6c52c1528cc85e64dc3d2ede",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
