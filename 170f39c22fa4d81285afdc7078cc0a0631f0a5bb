      "writtenOn": "2018-10-16T02:02:18Z",
      "side": 1,
      "message": "This lower bound is sensitive to clock synchronization. How about:\n\n timeout \u003d 10 * time.Minute\n lower :\u003d start.Add(9 * time.Minute)\n upper :\u003d start.Add(11 * time.Minute)",
