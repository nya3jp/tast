    {
      "key": {
        "uuid": "6aa5850d_a1bcc62c",
        "filename": "src/chromiumos/tast/internal/sshconfig/sshconfig_test.go",
        "patchSetId": 12
      },
      "lineNbr": 83,
      "author": {
        "id": 1118346
      },
      "writtenOn": "2020-08-21T05:33:56Z",
      "side": 1,
      "message": "This test contains many significantly different test scenarios. Generally a unit test should concentrate on a single aspect of the behavior of an API. For example,\n\n TestGetReadHostFromFiles_Success - GetReadHostFromFiles successfully resolves a host name using a config\n TestGetReadHostFromFiles_NoMatch - GetReadHostFromFiles returns the original host name due to no match\n ...\n TestGetReadHostFromFiles_MatchBlock - GetReadHostFromFiles does not support \"match\" block\n ...\n TestGetReadHostFromFiles_MissingInitialFiles - GetReadHostFromFiles succeeds even if initial files are missing\n TestGetReadHostFromFiles_MissingIncludeFiles - GetReadHostFromFiles succeeds even if included files are missing\n\nI recommend reading some articles about unit testing. There are several good internal resources, e.g. go/unit-test-practices.",
      "range": {
        "startLine": 83,
        "startChar": 5,
        "endLine": 83,
        "endChar": 29
      },
      "revId": "25a7b89ba13db41735f87cded32b14c61c89cc97",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
    {
      "key": {
