    {
      "key": {
        "uuid": "023283b4_ca564985",
        "filename": "src/chromiumos/tast/host/exec.go",
        "patchSetId": 1
      },
      "lineNbr": 245,
      "author": {
        "id": 1115919
      },
      "writtenOn": "2019-06-11T16:46:22Z",
      "side": 1,
      "message": "Raw goroutine may simpler?\n\nt :\u003d make(chan bool, 1)\nretc :\u003d make(chan error, 1)\n\ngo func() {\n  retc \u003c- c.sess.Start(...)\n  if ok :\u003d \u003c- t; !ok {\n    c.sess.Close()\n  }\n}\n\nvar err error\nselect {\ncase e :\u003d \u003c- retc:\n  err \u003d e\ncase \u003c- ctx.Done():\n  err \u003d ctx.Err()\n}\n\nt \u003c- err !\u003d nil\nif err !\u003d nil {\n  ... error handling ...\n}\nreturn err\n\nThis pattern seems to be shared with the following one?",
      "parentUuid": "aa74265d_6d7ccb57",
      "range": {
        "startLine": 240,
        "startChar": 1,
        "endLine": 245,
        "endChar": 4
      },
      "revId": "dde94c74638f2fb9948169e7d7e085fc12bd817b",
