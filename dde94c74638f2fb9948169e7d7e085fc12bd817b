      "writtenOn": "2019-06-11T15:45:11Z",
      "side": 1,
      "message": "Looks race condition. doAsync internally creates a goroutine. So, the order of c.sess.Start() and c.sess.Close() is arbitrary.",
      "range": {
        "startLine": 240,
        "startChar": 1,
        "endLine": 245,
        "endChar": 4
      },
      "revId": "dde94c74638f2fb9948169e7d7e085fc12bd817b",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
