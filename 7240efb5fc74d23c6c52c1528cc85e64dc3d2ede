        "id": 1118346
      },
      "writtenOn": "2019-03-28T09:28:10Z",
      "side": 1,
      "message": "optional: It might be easier to set cmd.Stdin \u003d bytes.NewBuffer(marshaledArgs) rather than dealing with StdinPipe; handling process I/O is tricky, but you can forget about stdin if you go with this way.",
      "range": {
        "startLine": 173,
        "startChar": 1,
        "endLine": 173,
        "endChar": 60
      },
      "revId": "7240efb5fc74d23c6c52c1528cc85e64dc3d2ede",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
