      "writtenOn": "2020-11-09T09:37:06Z",
      "side": 1,
      "message": "This function can be written in two lines:\n\n startIndex :\u003d numTests * shardIndex / totalShards\n endIndex :\u003d numTests * (shardIndex + 1) / totalShards",
      "range": {
        "startLine": 133,
        "startChar": 0,
        "endLine": 171,
        "endChar": 1
      },
      "revId": "0ca5f5ed57639db3130aa3b283843d9672fb98e0",
