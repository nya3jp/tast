      "writtenOn": "2020-02-19T16:54:15Z",
      "side": 1,
      "message": "This is used from chromiumos/tast/testing package to merge ExtraHardwareDeps in Param and its enclosing testing.Test\u0027s HardwareDeps.\n\nIs there any approach to hide from other packages in the case...?",
      "parentUuid": "72688b7c_f8165844",
      "range": {
        "startLine": 66,
        "startChar": 5,
        "endLine": 66,
        "endChar": 10
      },
      "revId": "49278c80c3d2dad43675b3b8b8307dd4e489d977",
