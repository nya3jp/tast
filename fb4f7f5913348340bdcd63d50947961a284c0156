    {
      "key": {
        "uuid": "d1ea1841_8dd3cd64",
        "filename": "src/chromiumos/tast/common/host/host.go",
        "patchSetId": 1
      },
      "lineNbr": 55,
      "author": {
        "id": 1000042
      },
      "writtenOn": "2017-08-24T00:02:20Z",
      "side": 1,
      "message": "the differences in how existing destination paths are handled irks me a bit. curious to get your thoughts.",
      "revId": "fb4f7f5913348340bdcd63d50947961a284c0156",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
